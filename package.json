{
  "name": "zoxide-doctor",
  "version": "0.2.0",
  "description": "A small LLM-powered doctor for bad zoxide jumps.",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aurokin/zoxide-doctor.git"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "bin": {
    "zdr": "./dist/zdr"
  },
  "scripts": {
    "check": "bun run tsc --noEmit",
    "test": "bun test",
    "verify": "bun run check && bun test && bun run build",
    "start": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --compile --outfile dist/zdr",
    "install:dev": "bun run scripts/install-dev-build.ts",
    "release:check-version": "bun run scripts/check-release-version.ts",
    "release:build": "bun run scripts/build-release.ts",
    "release:formula": "bun run scripts/generate-homebrew-formula.ts",
    "release:prepare": "bun run scripts/prepare-release.ts",
    "smoke": "bun run src/cli.ts --version",
    "timing": "bun run build && bun run scripts/timing-baseline.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.167",
    "@earendil-works/pi-ai": "^0.80.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "@google/genai",
    "protobufjs"
  ]
}
